# Copy to .env for local development (never commit the real .env).
# In production, set these under this Vercel project's Environment Variables
# (a separate project from the storefront's — values are the same, but
# Vercel projects don't share env vars, so re-enter them here too).

# --- Supabase (server-only, used by api/ functions) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase Auth (client-safe, used by src/lib/supabaseClient.ts) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Comma-separated list of admin emails allowed to sign in here
ADMIN_EMAILS=
