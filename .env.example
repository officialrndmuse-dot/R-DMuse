# Copy this file to .env for local development (never commit the real .env).
# In production, set these under Vercel Project Settings -> Environment Variables.

# --- Supabase (server-only, used by api/ functions) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Razorpay (server-only) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Shiprocket (server-only) ---
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
# Must exactly match a pickup location nickname configured in the Shiprocket dashboard
SHIPROCKET_PICKUP_LOCATION=

# --- Firebase (client-safe, used by src/lib/firebaseClient.ts) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# --- Firebase Admin (server-only, used by api/_lib/firebase.ts) ---
# Paste the service account JSON as one line (or base64-encode it) — never commit the real value.
FIREBASE_SERVICE_ACCOUNT_KEY=
# Comma-separated list of admin emails allowed into /admin
ADMIN_EMAILS=
