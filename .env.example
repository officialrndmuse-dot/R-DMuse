# Copy this file to .env for local development (never commit the real .env).
# In production, set these under Vercel Project Settings -> Environment Variables.

# --- Supabase (server-only, used by api/ functions) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase Auth (client-safe, used by src/lib/supabaseClient.ts) ---
# Same project as above; the anon/public key is safe to expose (it can't
# read/write orders/profiles/addresses/wishlist/returns directly -- those
# tables have RLS enabled with zero public policies).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Razorpay (server-only) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Shiprocket (server-only) ---
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
# Must exactly match a pickup location nickname configured in the Shiprocket dashboard
SHIPROCKET_PICKUP_LOCATION=
# The pincode of that same pickup location -- used for live shipping-rate lookups
SHIPROCKET_PICKUP_PINCODE=

# Comma-separated list of admin emails allowed into /admin
ADMIN_EMAILS=
